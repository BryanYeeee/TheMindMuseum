ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
MESHY_API_KEY=your_meshy_key_here

# Required for Meshy to fetch images (must be publicly reachable).
# Run: ngrok http 5000  →  copy the https URL here.
# Without this, 3D generation is skipped and model_url will be null.
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app
